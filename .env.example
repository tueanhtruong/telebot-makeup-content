# Telegram API Credentials
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram Phone Number (with country code)
TELEGRAM_PHONE_NUMBER=

# Telegram Session Name (optional, default: telethon_session)
TELEGRAM_SESSION_NAME=telethon_session

# Time window in seconds for polling messages (default: 7200 = 2 hours)
TELEGRAM_WINDOW_SECONDS=7200

# Maximum number of messages to fetch per poll (default: 400)
TELEGRAM_FETCH_LIMIT=400

# Gemini AI API Key (for message summarization)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Facebook Page Access Token (for posting to Facebook)
FACEBOOK_TOKEN=

# Facebook Page ID (for posting to Facebook)
FACEBOOK_PAGE_ID=

# Media channel username for media_action.py (comma-separated, without @)
# Example: media_channel,another_media_channel
TELEGRAM_CHANNEL_MEDIA_USERNAME=

# Media channel ID for media_action.py (comma-separated)
# Example: 1234567890,9876543210
TELEGRAM_CHANNEL_MEDIA_ID=

# Time window in seconds for polling media messages (default: 1200 = 20 minutes)
TELEGRAM_MEDIA_WINDOW_SECONDS=1200

# Maximum number of messages to fetch per poll for media (default: 100)
TELEGRAM_MEDIA_FETCH_LIMIT=100
FACEBOOK_APP_ID=

TELEGRAM_CHANNEL_1_USERNAME=
TELEGRAM_CHANNEL_1_ID=
TELEGRAM_CHANNEL_2_USERNAME=
TELEGRAM_CHANNEL_2_ID=

GROK_API_KEY=
# Optional:
GROK_MODEL=grok-4-fast-reasoning  # defaults to grok-4-fast-reasoning
GROK_BASE_URL=  # defaults to this

# OPENROUTER API_KEY
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free